# Copy to `.env` for local secrets (never commit `.env`).
# All keys use the MANUSIFT_ prefix (see manusift/config.py).

# --- LLM (optional; offline screen works without keys) ---
# MANUSIFT_DEFAULT_LLM_PROVIDER=openai
# MANUSIFT_OPENAI_API_KEY=
# MANUSIFT_OPENAI_BASE_URL=https://api.openai.com/v1
# MANUSIFT_OPENAI_MODEL=gpt-4o-mini

# Anthropic-compatible (Claude, or proxies such as DeepSeek Anthropic API)
# MANUSIFT_ANTHROPIC_API_KEY=
# MANUSIFT_ANTHROPIC_BASE_URL=https://api.anthropic.com
# MANUSIFT_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Disable LLM enrichment entirely (same as CLI --no-llm)
# MANUSIFT_LLM_MAX_CONCURRENCY=0

# --- Workspace ---
# MANUSIFT_WORKSPACE_DIR=./data/jobs

# --- Optional network detectors (off by default) ---
# MANUSIFT_CROSSREF_ENABLED=0
# MANUSIFT_OPENALEX_ENABLED=0
